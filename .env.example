# QuantEdge AI — environment template (do not commit real secrets)
# Copy to .env and fill in values locally / in your secret store.

APP_ENV=dev
LOG_LEVEL=info

# Comma-separated origins for CORS (Vite default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://quantedge:quantedge@localhost:5432/quantedge

# Redis
REDIS_URL=redis://localhost:6379/0

# Market data provider (names depend on vendor)
MARKET_DATA_API_KEY=
MARKET_DATA_WS_URL=

# LLM (single provider for V1)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Vector store
CHROMA_PERSIST_DIR=./.chroma
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

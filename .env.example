# QuantEdge AI — environment template (do not commit real secrets)
# Copy to .env and fill in values locally / in your secret store.

APP_ENV=dev
LOG_LEVEL=info
# true = JSON logs (better for aggregators); false = human-readable console
LOG_JSON=false

# Set by pytest (do not use in production)
# TESTING=1

# Comma-separated origins for CORS (Vite default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://quantedge:quantedge@localhost:5432/quantedge

# Redis
REDIS_URL=redis://localhost:6379/0

# Phase 3 — market pipeline (mock 1m → 5m by default)
MARKET_SYMBOLS=ES,NQ
MOCK_MARKET_DATA=true
MOCK_TICK_SECONDS=0.25
RETENTION_MONTHS=6

# Phase 6 — WebSocket + bar→insight streaming (when MOCK_MARKET_DATA=true)
WS_BROADCAST_ENABLED=true
STREAM_INSIGHTS_ON_BAR=true

# Market data provider (names depend on vendor)
MARKET_DATA_API_KEY=
MARKET_DATA_WS_URL=

# LLM (single provider for V1)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Vector store (Phase 5 RAG)
CHROMA_PERSIST_DIR=./.chroma
KB_DIR=kb
KB_VERSION=1.0.0
RAG_TOP_K=5
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4o-mini
# Set true to force rule-based mock insights (no OpenAI chat)
RAG_MOCK_INSIGHTS=false

# Ingest KB into Chroma (from repo root, venv active):
#   cd backend && quantedge-ingest ingest
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

# Phase 7 — React dashboard (Vite reads frontend/.env)
# Leave unset to use same-origin + Vite dev proxy to localhost:8000.
# VITE_API_BASE_URL=http://localhost:8000
